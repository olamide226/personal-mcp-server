# Runtime
MCP_TRANSPORT=http
MCP_HOST=127.0.0.1
MCP_PORT=3000
# MCP_BEARER_TOKEN is optional. Set it to require auth on all requests.
# MCP_BEARER_TOKEN=replace-with-a-long-random-token
# MCP_ALLOWED_ORIGINS defaults to * (allow all). Set to restrict origins.
# MCP_ALLOWED_ORIGINS=http://localhost:3000
# Set to false to disable the setup_* tools (only .env config then).
# MCP_ENABLE_SETUP_TOOLS=false

# Turso/libSQL. Use file:local.db for local development.
# For pods/containers, set an absolute path to persist state:
#   TURSO_DATABASE_URL=file:/data/my-server.db
# Or use a Turso remote database:
#   TURSO_DATABASE_URL=libsql://your-db-your-org.turso.io
# Can also be configured at runtime via the setup_database tool.
TURSO_DATABASE_URL=file:local.db
# TURSO_AUTH_TOKEN=
# TURSO_SYNC_URL=
# TURSO_SYNC_INTERVAL_MS=60000

# Gmail OAuth — can also be configured at runtime via setup_gmail_oauth_start/complete.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:3000/oauth/google/callback
GOOGLE_REFRESH_TOKEN=
GOOGLE_OAUTH_STATE=replace-with-random-state

# Custom IMAP mailbox — can also be configured at runtime via setup_custom_mail_imap.
CUSTOM_IMAP_HOST=
CUSTOM_IMAP_PORT=993
CUSTOM_IMAP_SECURE=true
CUSTOM_IMAP_USER=
CUSTOM_IMAP_PASSWORD=
CUSTOM_IMAP_MAILBOX=INBOX

# Custom SMTP — can also be configured at runtime via setup_custom_mail_smtp.
CUSTOM_SMTP_HOST=
CUSTOM_SMTP_PORT=587
CUSTOM_SMTP_SECURE=false
CUSTOM_SMTP_USER=
CUSTOM_SMTP_PASSWORD=

# Sending defaults
EMAIL_DEFAULT_FROM=
EMAIL_CONFIRMATION_TTL_SECONDS=600

# Slack — can also be configured at runtime via setup_slack_webhook.
SLACK_WEBHOOK_URL=

{
  "name": "personal-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Private MCP server for personal email, Slack notifications, and soul docs in remote SQLite.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:stdio": "MCP_TRANSPORT=stdio node dist/index.js",
    "test": "vitest run tests",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.7",
    "googleapis": "^173.0.0",
    "imapflow": "^1.0.194",
    "mailparser": "^3.9.10",
    "nodemailer": "^9.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
